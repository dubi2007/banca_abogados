---
import '../../styles/pages/nosotros.css';
import Layout from '../../layouts/Layout.astro';
import aboutData from '../../data/about.json';
import es from '../../data/es.json';
import en from '../../data/en.json';

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = lang === 'en' ? en : es;
const hist = aboutData.historia[lang as 'es' | 'en'];
const mision = aboutData.mision[lang as 'es' | 'en'];
const vision = aboutData.vision[lang as 'es' | 'en'];
const fundadora = aboutData.fundadora[lang as 'es' | 'en'];
const comp = aboutData.compromiso[lang as 'es' | 'en'];
const heroImg = 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=1600&q=80';

const svgIcons: Record<string, string> = {
  eye: '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>',
  lightbulb: '<path d="M9 18h6M10 22h4"/><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .5 2.5 1.5 3.5.8.8 1.3 1.5 1.5 2.5"/>',
  star: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  heart: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>',
  leaf: '<path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.7 10-10 10zM2 21c0-3 1.9-5.8 4.5-6.5"/>'
};
---

<Layout title={t["nav.about"]} lang={lang}>
	<div class="page-header" style={`background-image: url('${heroImg}')`}>
		<h1>{t["nav.about"]}</h1>
	</div>

	<!-- HISTORIA -->
	<section class="about-section container">
		<div class="history">
			<h2>Faynshteyn Abogados & Consultores</h2>
			<div class="v-line-sm"></div>
			<p>{hist}</p>
		</div>
	</section>

	<!-- MISIÓN Y VISIÓN -->
	<section class="mv-section">
		<div class="container mv-grid">
			<div class="mv-card">
				<h3>{mision.title}</h3>
				<div class="mv-line"></div>
				<p>{mision.text}</p>
			</div>
			<div class="mv-card">
				<h3>{vision.title}</h3>
				<div class="mv-line"></div>
				<p>{vision.text}</p>
			</div>
		</div>
	</section>

	<!-- FUNDADORA -->
	<section class="fundadora-section container">
		<div class="fundadora-grid">
			<div class="fundadora-image">
				<img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=600&q=80" alt={fundadora.name} />
			</div>
			<div class="fundadora-info">
				<span class="fundadora-label">{fundadora.title}</span>
				<h2>{fundadora.name}</h2>
				<h3 class="fundadora-role">{fundadora.role}</h3>
				<div class="mv-line"></div>
				<p>{fundadora.bio}</p>
			</div>
		</div>
	</section>

	<!-- COMPROMISO -->
	<section class="compromiso-section">
		<div class="container">
			<h2>{comp.title}</h2>
			<div class="cards-grid">
				{comp.cards.map((card: { title: string; icon: string }) => (
					<div class="compromiso-card">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={svgIcons[card.icon] || svgIcons.star} />
						<h3>{card.title}</h3>
					</div>
				))}
			</div>
		</div>
	</section>
</Layout>
