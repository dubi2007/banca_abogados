---
import '../../styles/pages/contactenos.css';
import Layout from '../../layouts/Layout.astro';
import es from '../../data/es.json';
import en from '../../data/en.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = lang === 'en' ? en : es;
const labels = lang === 'en'
  ? { name: 'Full Name', email: 'Email', phone: 'Phone', message: 'Message', send: 'SUBMIT' }
  : { name: 'Nombre completo', email: 'Correo electrónico', phone: 'Teléfono', message: 'Mensaje', send: 'ENVIAR' };
---

<Layout title={t["nav.contact"]} lang={lang}>
	<section class="contact-hero">
		<div class="contact-overlay"></div>
		<div class="contact-content">
			<h1>{t["nav.contact"]}</h1>
			<form class="contact-form">
				<div class="form-group">
					<label>{labels.name}</label>
					<input type="text" required />
				</div>
				<div class="form-group">
					<label>{labels.email}</label>
					<input type="email" required />
				</div>
				<div class="form-group">
					<label>{labels.phone}</label>
					<input type="tel" />
				</div>
				<div class="form-group">
					<label>{labels.message}</label>
					<textarea rows="5" required></textarea>
				</div>
				<button type="submit" class="submit-btn">{labels.send}</button>
			</form>
		</div>
	</section>
</Layout>
