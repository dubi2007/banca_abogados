---
import '../../styles/pages/home.css';
import Layout from '../../layouts/Layout.astro';
import VideoHero from '../../components/VideoHero.astro';
import homeData from '../../data/home.json';
import es from '../../data/es.json';
import en from '../../data/en.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = lang === 'en' ? en : es;
const heroData = homeData.hero[lang as 'es' | 'en'];
const novedadesData = homeData.novedades_empresas[lang as 'es' | 'en'];
const ctaText = lang === 'en' ? 'ABOUT US' : 'QUIÉNES SOMOS';
---

<Layout title={heroData.title} lang={lang}>
	<VideoHero
		videoSrc={homeData.hero.videoSrc}
		videoPoster={homeData.hero.videoPoster}
		title={heroData.title}
		subtitle={heroData.subtitle}
		ctaText={ctaText}
		ctaHref={`/${lang}/nosotros`}
	/>

	<!-- AREAS PREVIEW -->
	<section class="home-areas">
		<div class="container">
			<div class="section-title">
				<h2>{lang === 'en' ? 'PRACTICE AREAS' : 'ÁREAS DE PRÁCTICA'}</h2>
				<p>{lang === 'en' ? 'Excellence in every specialization' : 'Excelencia en cada especialización'}</p>
			</div>
			<div class="areas-preview-grid">
				<a href={`/${lang}/areas/derecho-corporativo`} class="area-preview-card">
					<span class="area-num">01</span>
					<h3>{lang === 'en' ? 'Corporate Law' : 'Derecho Corporativo'}</h3>
				</a>
				<a href={`/${lang}/areas/fusiones-adquisiciones`} class="area-preview-card">
					<span class="area-num">02</span>
					<h3>{lang === 'en' ? 'Mergers & Acquisitions' : 'Fusiones y Adquisiciones'}</h3>
				</a>
				<a href={`/${lang}/areas/litigios`} class="area-preview-card">
					<span class="area-num">03</span>
					<h3>{lang === 'en' ? 'Litigation' : 'Litigios'}</h3>
				</a>
				<a href={`/${lang}/areas/derecho-tributario`} class="area-preview-card">
					<span class="area-num">04</span>
					<h3>{lang === 'en' ? 'Tax Law' : 'Derecho Tributario'}</h3>
				</a>
			</div>
			<div class="view-more-link">
				<a href={`/${lang}/areas`}>{lang === 'en' ? 'VIEW ALL AREAS →' : 'VER TODAS LAS ÁREAS →'}</a>
			</div>
		</div>
	</section>

	<!-- STATISTICS SECTION -->
	<section class="home-stats">
		<div class="container">
			<div class="stats-grid">
				{homeData.stats[lang as 'es' | 'en'].map((stat: { label: string; value: string }) => (
					<div class="stat-item">
						<span class="stat-value">{stat.value}</span>
						<span class="stat-label">{stat.label}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- PARALLAX SECTION 1 - RECONOCIMIENTOS -->
	<section class="parallax-section" data-parallax style="background-image: url('https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600&q=80')">
		<div class="parallax-overlay"></div>
		<div class="parallax-content container">
			<span class="parallax-label">{lang === 'en' ? 'THE MAIN LEGAL GUIDES CONSIDER US' : 'LAS PRINCIPALES GUÍAS LEGALES NOS CONSIDERAN'}</span>
			<h2>{lang === 'en' ? 'LEADING FIRM IN PERU' : 'FIRMA LÍDER EN PERÚ'}</h2>
			<p>{lang === 'en' ? 'Maintaining a high level of specialization in various areas of law' : 'Manteniendo un alto nivel de especialización en diversas áreas del derecho'}</p>
			<a href={`/${lang}/nosotros`} class="btn-outline">{t["nav.about"]}</a>
		</div>
	</section>

	<!-- COMMITMENT SECTION -->
	<section class="home-commitment">
		<div class="container">
			<div class="section-title">
				<h2>{homeData.commitment[lang as 'es' | 'en'].title}</h2>
			</div>
			<div class="commitment-grid">
				{homeData.commitment[lang as 'es' | 'en'].items.map((item: { title: string; desc: string }) => (
					<div class="commitment-item">
						<h3>{item.title}</h3>
						<p>{item.desc}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- NOVEDADES -->
	<section class="home-novedades">
		<div class="container">
			<div class="section-title">
				<h2>{novedadesData.title}</h2>
			</div>
			<div class="carousel">
				{novedadesData.items.map((item: { title: string; date: string }) => (
					<div class="card">
						<span class="date">{item.date}</span>
						<h3>{item.title}</h3>
						<a href={`/${lang}/novedades`} class="read-more">→</a>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- FAQ SECTION -->
	<section class="home-faq">
		<div class="container">
			<div class="section-title">
				<h2>{homeData.faqs[lang as 'es' | 'en'].title}</h2>
			</div>
			<div class="faq-accordion">
				{homeData.faqs[lang as 'es' | 'en'].items.map((item: { q: string; a: string }) => (
					<div class="faq-item">
						<button class="faq-question">
							{item.q}
							<span class="icon"></span>
						</button>
						<div class="faq-answer">
							<p>{item.a}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- PARALLAX SECTION 2 - CONTACTO -->
	<section class="parallax-section" data-parallax style="background-image: url('https://images.unsplash.com/photo-1507679799987-c73779587ccf?w=1600&q=80')">
		<div class="parallax-overlay"></div>
		<div class="parallax-content container" style="text-align:center;">
			<span class="parallax-label">{lang === 'en' ? 'WE WANT TO HEAR FROM YOU' : 'QUEREMOS SABER DE USTED'}</span>
			<h2>{lang === 'en' ? 'CONTACT US' : 'CONTÁCTENOS'}</h2>
			<p>{lang === 'en' ? 'Let us know how we can help with your legal needs' : 'Permítanos saber cómo podemos ayudarle con sus necesidades legales'}</p>
			<a href={`/${lang}/contactenos`} class="btn-outline">{t["nav.contact"]}</a>
		</div>
	</section>
</Layout>

<script>
	function initAnimations() {
		// FAQ ACCORDION
		const faqItems = document.querySelectorAll('.faq-item');
		faqItems.forEach(item => {
			const question = item.querySelector('.faq-question');
			question?.addEventListener('click', () => {
				const isOpen = item.classList.contains('active');
				// Close all other items
				faqItems.forEach(otherItem => otherItem.classList.remove('active'));
				// Toggle current
				if (!isOpen) item.classList.add('active');
			});
		});

		// PARALLAX EFFECT
		const parallaxSections = document.querySelectorAll('[data-parallax]');
		
		function handleParallax() {
			parallaxSections.forEach(section => {
				const rect = (section as HTMLElement).getBoundingClientRect();
				const scrolled = window.scrollY;
				// Only animate if section is in viewport
				if (rect.top < window.innerHeight && rect.bottom > 0) {
					const rate = (rect.top) * 0.15; // Slower, smoother rate
					(section as HTMLElement).style.backgroundPosition = `center ${rate}px`;
				}
			});
		}

		if (window.innerWidth > 768) {
			window.addEventListener('scroll', handleParallax, { passive: true });
		}

		// FADE-IN ON SCROLL
		const observerOptions = { 
			threshold: 0.15, 
			rootMargin: '0px 0px -80px 0px' 
		};

		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
					// Once visible, no need to observe anymore for performance
					observer.unobserve(entry.target);
				}
			});
		}, observerOptions);

		document.querySelectorAll('.area-preview-card, .card, .section-title, .parallax-content, .stat-item, .commitment-item, .faq-item').forEach(el => {
			el.classList.add('fade-up');
			observer.observe(el);
		});
	}

	// Initialize on first load and after every View Transition
	document.addEventListener('astro:page-load', initAnimations);
</script>
