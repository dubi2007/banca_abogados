---
import '../styles/components/header.css';
import es from '../data/es.json';
import en from '../data/en.json';
import SocialIcons from './SocialIcons.astro';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = lang === 'en' ? en : es;
---

<header class="main-header" id="mainHeader">
  <div class="top-bar container">
    <SocialIcons />
    <div class="lang-selector">
      <a href="/es/" class={lang === 'es' ? 'active' : ''}>ES</a>
      <span class="lang-separator">|</span>
      <a href="/en/" class={lang === 'en' ? 'active' : ''}>EN</a>
    </div>
  </div>
  <nav class="navbar container">
    <div class="logo">
      <a href={`/${lang}/`}>FAYNSHTEYN</a>
    </div>
    <button class="mobile-toggle" id="mobileToggle" aria-label="Menu">
      <span></span>
      <span></span>
    </button>
    <ul class="nav-links" id="navLinks">
      <li><a href={`/${lang}/nosotros`}>{t["nav.about"]}</a></li>
      <li><a href={`/${lang}/areas`}>{t["nav.areas"]}</a></li>
      <li><a href={`/${lang}/sedes`}>{t["nav.locations"]}</a></li>
      <li><a href={`/${lang}/directorio`}>{t["nav.directory"]}</a></li>
      <li><a href={`/${lang}/productos-legales`}>{t["nav.products"]}</a></li>
      <li><a href={`/${lang}/novedades`}>{t["nav.news"]}</a></li>
      <li><a href={`/${lang}/contactenos`}>{t["nav.contact"]}</a></li>
    </ul>
  </nav>
</header>

<script>
  function initHeader() {
    const header = document.getElementById('mainHeader');
    const toggle = document.getElementById('mobileToggle');
    const links = document.getElementById('navLinks');

    // Mobile Toggle
    if (toggle && links) {
      toggle.addEventListener('click', () => {
        links.classList.toggle('open');
        toggle.classList.toggle('active');
      });
    }

    // Scroll effect
    const handleScroll = () => {
      if (window.scrollY > 50) {
        header?.classList.add('scrolled');
      } else {
        header?.classList.remove('scrolled');
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll(); // Initial check
  }

  document.addEventListener('astro:page-load', initHeader);
</script>
